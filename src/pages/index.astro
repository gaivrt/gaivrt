---
/**
 * Layer 0 — Particle entrance.
 * Particles form "GAIVRT" with painting-inspired color palettes.
 * Returns visitors (>3 visits) skip directly to /surface/.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import VisitTracker from '../components/shared/VisitTracker.astro';
import ParticleEntrance from '../components/entrance/ParticleEntrance.tsx';
---

<BaseLayout title="GAIVRT">
  <VisitTracker />
  <main id="entrance">
    <ParticleEntrance client:only="solid-js" />
    <noscript>
      <meta http-equiv="refresh" content="0;url=/surface/" />
    </noscript>
  </main>
</BaseLayout>

<style>
  #entrance {
    background: #f0ede4;
    position: fixed;
    inset: 0;
  }

  #entrance :global(astro-island) {
    display: block;
    width: 100%;
    height: 100%;
  }

  #entrance :global(.entrance-container) {
    width: 100%;
    height: 100%;
    position: relative;
  }

  #entrance :global(.entrance-hint) {
    position: absolute;
    bottom: 12%;
    left: 0;
    right: 0;
    text-align: center;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 14px;
    letter-spacing: 0.1em;
    color: rgba(80, 75, 65, 0.5);
    pointer-events: none;
    user-select: none;
  }
</style>
