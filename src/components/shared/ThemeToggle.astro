---
/**
 * Three-state theme toggle: light → dark → system → light.
 * Icon shows current preference. Click cycles to next.
 * Persists to localStorage('gaivrt_theme').
 */
---

<button
  id="theme-toggle"
  type="button"
  aria-label="切换主题"
  title="切换主题"
>
  <!-- Light: sun -->
  <svg class="icon-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
    <circle cx="12" cy="12" r="4.5" />
    <path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
  </svg>
  <!-- Dark: moon -->
  <svg class="icon-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
  <!-- System: monitor -->
  <svg class="icon-system" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <rect x="2" y="3" width="20" height="14" rx="2" />
    <line x1="8" y1="21" x2="16" y2="21" />
    <line x1="12" y1="17" x2="12" y2="21" />
  </svg>
</button>

<style>
  #theme-toggle {
    position: fixed;
    top: var(--space-lg);
    right: var(--space-lg);
    z-index: 200;
    background: none;
    border: none;
    padding: 6px;
    cursor: pointer;
    color: var(--surface-text-secondary);
    opacity: 0.35;
    transition: opacity var(--transition-smooth), color var(--transition-smooth);
    line-height: 0;
  }

  #theme-toggle:hover {
    opacity: 1;
    color: var(--surface-accent);
  }

  #theme-toggle svg {
    width: 18px;
    height: 18px;
  }

  /* Hide all icons by default, show based on data-theme-pref */
  .icon-light, .icon-dark, .icon-system { display: none; }

  :global([data-theme-pref="light"]) .icon-light { display: block; }
  :global([data-theme-pref="dark"]) .icon-dark { display: block; }
  :global([data-theme-pref="system"]) .icon-system { display: block; }

  @media (max-width: 480px) {
    #theme-toggle {
      top: var(--space-md);
      right: var(--space-md);
    }
  }
</style>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    const CYCLE: Record<string, string> = { light: 'dark', dark: 'system', system: 'light' };

    function resolve(pref: string): string {
      if (pref === 'light' || pref === 'dark') return pref;
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    btn.addEventListener('click', () => {
      const cur = document.documentElement.getAttribute('data-theme-pref') || 'system';
      const next = CYCLE[cur] || 'light';
      const effective = resolve(next);
      document.documentElement.setAttribute('data-theme', effective);
      document.documentElement.setAttribute('data-theme-pref', next);
      try { localStorage.setItem('gaivrt_theme', next); } catch {}
    });

    // Follow system preference changes when pref is 'system'
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      const pref = document.documentElement.getAttribute('data-theme-pref');
      if (pref !== 'system') return;
      document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
    });
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
