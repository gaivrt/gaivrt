---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: '/surface/', label: 'Home' },
  { href: '/surface/research', label: 'Research' },
  { href: '/surface/publications', label: 'Publications' },
  { href: '/surface/projects', label: 'Projects' },
  { href: '/surface/blog', label: 'Blog' },
  { href: '/surface/cv', label: 'CV' },
];
---

<nav class="nav" aria-label="Primary navigation">
  <a href="/surface/" class="nav-brand">GAIVRT</a>
  <ul class="nav-links">
    {links.map((link, i) => (
      <>
        {i > 0 && <li class="nav-sep" aria-hidden="true">·</li>}
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      </>
    ))}
  </ul>
</nav>

<style>
  .nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-sm) 0;
    gap: var(--space-sm);
  }

  .nav-brand {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 1rem;
    letter-spacing: 0.2em;
  }

  .nav-links {
    display: flex;
    gap: 0.4rem;
    list-style: none;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav-sep {
    color: var(--surface-text-secondary);
    opacity: 0.35;
    font-size: 0.75rem;
    display: flex;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 0.8rem;
    color: var(--surface-text-secondary);
    letter-spacing: 0.04em;
    transition: color var(--transition-smooth);
    text-decoration-line: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
  }

  .nav-link:hover {
    color: var(--surface-accent);
    text-decoration-color: var(--surface-accent);
  }

  .nav-link.active {
    color: var(--surface-text);
  }

  @media (max-width: 767px) {
    .nav-links { gap: 0.2rem 0.5rem; font-size: 0.75rem; }
    .nav-sep { display: none; }
  }
</style>
