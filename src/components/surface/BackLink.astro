---
import '../../styles/back-link.css';

interface Props {
  href?: string;
  label?: string;
}
const { href = '/surface/', label = 'GAIVRT' } = Astro.props;
---

<a href={href} class="site-back-link" aria-label={`Back to ${label}`}>
  <span class="site-back-arrow">←</span>
  <span class="site-back-name">{label}</span>
</a>
