---
import BaseLayout from './BaseLayout.astro';
import RippleCanvas from '../components/surface/RippleCanvas.tsx';
import InkBleedOverlay from '../components/surface/InkBleedOverlay.tsx';
import ThemeToggle from '../components/shared/ThemeToggle.astro';
import '../styles/layer1.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div id="ripple-mount" aria-hidden="true">
    <RippleCanvas client:only="solid-js" />
  </div>

  <!-- Ink bleed overlay -->
  <div id="inkbleed-overlay" aria-hidden="true">
    <InkBleedOverlay client:only="solid-js" />
  </div>

  <ThemeToggle />

  <div class="surface">
    <slot />
  </div>
</BaseLayout>

<style>
  #ripple-mount {
    position: fixed;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    mix-blend-mode: soft-light;
  }

  #inkbleed-overlay {
    position: fixed;
    inset: 0;
    z-index: 20;
    pointer-events: none;
  }
</style>
