---
import { getCollection } from 'astro:content';
import Layer1Layout from '../../../layouts/Layer1Layout.astro';
import BackLink from '../../../components/surface/BackLink.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layer1Layout title="Blog — GAIVRT">
  <div class="surface-container">
    <BackLink />
    <main>
      <h1>Blog</h1>
      {posts.length === 0 ? (
        <p class="empty">No posts yet. Check back soon.</p>
      ) : (
        <ul class="item-list">
          {posts.map((post, i) => (
            <li style={`--i: ${i}`}>
              <a href={`/surface/blog/${post.id}`}>
                <span class="item-title">{post.data.title}</span>
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('zh-CN')}
                </time>
              </a>
              {post.data.description && <p class="item-desc">{post.data.description}</p>}
              {post.data.tags.length > 0 && (
                <div class="item-tags">
                  {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                </div>
              )}
            </li>
          ))}
        </ul>
      )}
    </main>
  </div>
</Layer1Layout>

<style>
  h1 { margin: 0 0 var(--space-lg); }
  .empty { color: var(--surface-text-secondary); font-style: italic; }

  .item-list { list-style: none; padding: 0; }

  .item-list li {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--surface-border);
    opacity: 0;
    animation: rowReveal 0.4s ease forwards;
    animation-delay: calc(0.1s + var(--i) * 0.05s);
  }

  .item-list li a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-md);
  }

  .item-title {
    font-size: 1.1rem;
    font-weight: 500;
    transition: color var(--transition-smooth);
  }

  .item-list li a:hover .item-title {
    color: var(--surface-accent);
  }

  time {
    font-size: 0.85rem;
    color: var(--surface-text-secondary);
    white-space: nowrap;
  }

  .item-desc {
    margin-top: var(--space-xs);
    font-size: 0.9rem;
    color: var(--surface-text-secondary);
  }

  .item-tags {
    display: flex;
    gap: var(--space-xs);
    margin-top: var(--space-xs);
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.15em 0.5em;
    border-radius: 3px;
    background: var(--tag-bg);
    color: var(--surface-text-secondary);
  }

  @keyframes rowReveal {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 767px) {
    .item-list li a {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
