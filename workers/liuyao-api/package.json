{
  "name": "liuyao-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "tail:prod": "wrangler tail --env production",
    "migrate:local": "wrangler d1 migrations apply liuyao-dev --local",
    "migrate:dev": "wrangler d1 migrations apply liuyao-dev --remote",
    "migrate:prod": "wrangler d1 migrations apply liuyao-prod --remote --env production",
    "typecheck": "tsc --noEmit",
    "test": "esbuild test/security.test.ts --bundle --platform=node --format=esm --outfile=.test-dist/security.test.mjs && node --test .test-dist/security.test.mjs",
    "gen-codes": "tsx scripts/gen-codes.ts"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/node": "^25.6.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "esbuild": "^0.27.3",
    "wrangler": "^3.95.0"
  }
}
