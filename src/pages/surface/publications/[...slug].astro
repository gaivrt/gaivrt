---
import { getCollection, render } from 'astro:content';
import Layer1Layout from '../../../layouts/Layer1Layout.astro';
import BackLink from '../../../components/surface/BackLink.astro';

export async function getStaticPaths() {
  const items = await getCollection('publications');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<Layer1Layout title={`${item.data.title} — GAIVRT`}>
  <div class="surface-container">
    <BackLink />
    <main>
      <article class="prose">
        <header>
          <h1>{item.data.title}</h1>
          <div class="meta">
            {item.data.authors && <span>{item.data.authors}</span>}
            {item.data.venue && <span class="venue">{item.data.venue}</span>}
            {item.data.date && <time datetime={item.data.date.toISOString()}>{item.data.date.getFullYear()}</time>}
            {item.data.url && <a href={item.data.url} class="link">Paper</a>}
          </div>
        </header>
        <Content />
      </article>
      <a href="/surface/publications" class="back-link">← 返回 Publications</a>
    </main>
  </div>
</Layer1Layout>

<style>
  header { margin-bottom: var(--space-xl); }
  header h1 { margin-bottom: var(--space-sm); }
  .meta { display: flex; align-items: center; gap: var(--space-md); font-size: 0.85rem; color: var(--surface-text-secondary); flex-wrap: wrap; }
  .venue { font-style: italic; }
  .link { text-decoration: underline; }
  .back-link { display: inline-block; margin-top: var(--space-xl); font-size: 0.85rem; color: var(--surface-text-secondary); transition: color var(--transition-smooth); }
  .back-link:hover { color: var(--surface-text); }
</style>
