---
/**
 * Layer 2 — Depths index.
 * Floating text fragments, progressively unlocked by visit count.
 * Fragments are distributed in a 3×3 zone grid to prevent clustering.
 */
import Layer2Layout from '../../layouts/Layer2Layout.astro';
---

<Layer2Layout title="Depths — GAIVRT">
  <p class="depths-hint">你沉了下来。</p>
  <div id="depths-root"></div>
</Layer2Layout>

<script is:inline>
  (function() {
    /* ==========================================================
     *  碎片文本 — 在这里编辑
     *  BASE: 始终显示  |  EXTRA: visits >= 3 时额外显示
     * ========================================================== */
    var BASE_FRAGMENTS = [
      '有些东西不在表面。',
      '你为什么来这里？',
      '继续。',
      '不是所有人都会找到这里。',
    ];

    var EXTRA_FRAGMENTS = [
      '你开始理解了。',
      '表面只是开始。',
      '每一次回来，都会看到更多。',
    ];
    /* ========================================================== */

    var visits = 0;
    try {
      var d = JSON.parse(localStorage.getItem('gaivrt_visits') || '{}');
      visits = d.count || 0;
    } catch(e) {}

    var fragments = BASE_FRAGMENTS.slice();
    if (visits >= 3) fragments = fragments.concat(EXTRA_FRAGMENTS);

    var root = document.getElementById('depths-root');
    if (!root) return;

    // --- Zone grid layout (3×3, skip zone 7 = bottom-center for core link) ---
    var zones = [
      { left: [5, 28],  top: [8, 28] },   // 0: top-left
      { left: [33, 62], top: [5, 25] },    // 1: top-center
      { left: [67, 90], top: [8, 28] },    // 2: top-right
      { left: [3, 28],  top: [33, 55] },   // 3: mid-left
      { left: [35, 60], top: [30, 52] },   // 4: mid-center
      { left: [65, 92], top: [33, 55] },   // 5: mid-right
      { left: [5, 30],  top: [60, 80] },   // 6: bottom-left
      // zone 7 (bottom-center) RESERVED for core link
      { left: [65, 90], top: [60, 80] },   // 8: bottom-right
    ];

    // Shuffle zone assignment
    var indices = [];
    for (var z = 0; z < zones.length; z++) indices.push(z);
    for (var j = indices.length - 1; j > 0; j--) {
      var k = Math.floor(Math.random() * (j + 1));
      var tmp = indices[j]; indices[j] = indices[k]; indices[k] = tmp;
    }

    function rand(min, max) { return min + Math.random() * (max - min); }

    fragments.forEach(function(text, i) {
      var zone = zones[indices[i % indices.length]];
      var el = document.createElement('div');
      el.className = 'fragment';
      el.textContent = text;
      el.style.left = rand(zone.left[0], zone.left[1]) + '%';
      el.style.top = rand(zone.top[0], zone.top[1]) + '%';
      // Each fragment gets a unique drift speed
      var duration = (6 + Math.random() * 6).toFixed(1);
      var delay = (Math.random() * -10).toFixed(1);
      el.style.animationDuration = duration + 's';
      el.style.animationDelay = delay + 's';
      root.appendChild(el);
      setTimeout(function() { el.classList.add('visible'); }, 600 + i * 700);
    });

    // Core link — only if enough visits, always bottom-center (protected zone)
    if (visits >= 8) {
      var link = document.createElement('a');
      link.href = '/depths/core';
      link.className = 'core-link' + (visits < 10 ? ' flickering' : '');
      link.textContent = '更深处';
      root.appendChild(link);
      setTimeout(function() { link.classList.add('visible'); }, 600 + fragments.length * 700 + 500);
    }
  })();
</script>

<style>
  .depths-hint {
    text-align: center;
    padding-top: 40vh;
    font-size: 1rem;
    color: var(--depths-text-dim);
    animation: fadeIn 3s ease forwards;
    position: relative;
    z-index: 0;
  }

  #depths-root {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  #depths-root :global(.fragment),
  #depths-root :global(.core-link) {
    pointer-events: auto;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
