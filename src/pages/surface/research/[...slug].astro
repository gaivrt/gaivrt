---
import { getCollection, render } from 'astro:content';
import Layer1Layout from '../../../layouts/Layer1Layout.astro';
import BackLink from '../../../components/surface/BackLink.astro';

export async function getStaticPaths() {
  const items = await getCollection('research');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<Layer1Layout title={`${item.data.title} — GAIVRT`}>
  <div class="surface-container">
    <BackLink />
    <main>
      <article class="prose">
        <header>
          <h1>{item.data.title}</h1>
          <div class="meta">
            {item.data.status && <span class="status">{item.data.status}</span>}
            {item.data.date && <time datetime={item.data.date.toISOString()}>{item.data.date.toLocaleDateString('zh-CN')}</time>}
          </div>
        </header>
        <Content />
      </article>
      <a href="/surface/research" class="back-link">← 返回 Research</a>
    </main>
  </div>
</Layer1Layout>

<style>
  header { margin-bottom: var(--space-xl); }
  header h1 { margin-bottom: var(--space-sm); }
  .meta { display: flex; align-items: center; gap: var(--space-md); font-size: 0.85rem; color: var(--surface-text-secondary); }
  .status { padding: 0.15em 0.5em; border-radius: 3px; background: var(--tag-bg); }
  .back-link { display: inline-block; margin-top: var(--space-xl); font-size: 0.85rem; color: var(--surface-text-secondary); transition: color var(--transition-smooth); }
  .back-link:hover { color: var(--surface-text); }
</style>
