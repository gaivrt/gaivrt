---
import { getCollection, render } from 'astro:content';
import Layer1Layout from '../../layouts/Layer1Layout.astro';
import BackLink from '../../components/surface/BackLink.astro';

const items = await getCollection('about');
let InlineContent: any = null;
if (items.length > 0) {
  const result = await render(items[0]);
  InlineContent = result.Content;
}
---

<Layer1Layout title="About — GAIVRT">
  <div class="about-wrapper">
    <BackLink />
    <main>
      <h1>About</h1>
      {InlineContent ? (
        <article class="prose">
          <InlineContent />
        </article>
      ) : (
        <p class="empty">暂无内容。</p>
      )}
    </main>
  </div>
</Layer1Layout>

<style>
  .about-wrapper {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--space-lg);
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  main {
    max-width: var(--content-width);
    margin: 0 auto;
    width: 100%;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: 10vh;
  }

  h1 { margin: 0 0 var(--space-lg); }
  .empty { color: var(--surface-text-secondary); font-style: italic; }
</style>
