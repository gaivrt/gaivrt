---
import Layer1Layout from '../../layouts/Layer1Layout.astro';
import ObserverText from '../../components/surface/ObserverText.astro';

const toc = [
  { href: '/surface/blog', title: 'Blog', desc: '随想与记录' },
  { href: '/surface/research', title: 'Research', desc: '研究方向' },
  { href: '/surface/projects', title: 'Projects', desc: '开源项目' },
  { href: '/surface/publications', title: 'Publications', desc: '发表论文' },
  { href: '/surface/cv', title: 'CV', desc: '个人简历' },
];
---

<Layer1Layout title="GAIVRT — Home">
  <div class="surface-container home-page">
    <main>
      <section class="hero">
        <img src="/images/avatar.png" alt="GAIVRT" class="hero-avatar" />
        <h1 class="hero-name">GAIVRT</h1>
        <p class="hero-role">Researcher&ensp;·&ensp;Builder&ensp;·&ensp;Explorer</p>
        <p class="hero-bio">
          Exploring the intersection of<br />technology and human experience.
        </p>
      </section>

      <section class="toc">
        <nav class="toc-grid" aria-label="Site sections">
          {toc.map((item, i) => (
            <a href={item.href} class="toc-row" style={`--i: ${i}`}>
              <span class="toc-title">{item.title}</span>
              <span class="toc-desc">{item.desc}</span>
            </a>
          ))}
        </nav>
      </section>
    </main>
  </div>

  <ObserverText />
</Layer1Layout>

<style>
  .home-page {
    height: 100dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  @keyframes heroReveal {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes tocReveal {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  main {
    width: 100%;
  }

  /* ── Hero ── */
  .hero {
    text-align: center;
    padding: 0 0 2rem;
    position: relative;
  }

  .hero-avatar {
    width: 88px;
    height: 88px;
    border-radius: 6px;
    object-fit: cover;
    border: 2px solid var(--surface-border);
    margin: 0 auto 2.0rem;
    display: block;
    opacity: 0;
    animation: heroReveal 1.2s ease forwards;
    animation-delay: 0.1s;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 300;
    letter-spacing: 0.3em;
    color: var(--surface-text);
    opacity: 0;
    animation: heroReveal 1.2s ease forwards;
    animation-delay: 0.25s;
  }

  .hero-role {
    font-family: var(--font-display);
    font-size: clamp(0.8rem, 1.6vw, 0.95rem);
    font-weight: 400;
    font-style: italic;
    color: var(--surface-text-secondary);
    letter-spacing: 0.1em;
    margin-top: 0.8rem;
    opacity: 0;
    animation: heroReveal 1.2s ease forwards;
    animation-delay: 0.4s;
  }

  /* Decorative rule below role */
  .hero-role::after {
    content: '';
    display: block;
    width: clamp(40px, 12vw, 100px);
    height: 1px;
    background: var(--surface-border);
    margin: 1.5rem auto;
    opacity: 0;
    animation: heroReveal 1.2s ease forwards;
    animation-delay: 0.5s;
  }

  .hero-bio {
    font-size: 0.88rem;
    color: var(--surface-text-secondary);
    max-width: 340px;
    margin: 0 auto;
    line-height: 1.9;
    opacity: 0;
    animation: heroReveal 1.2s ease forwards;
    animation-delay: 0.6s;
  }

  /* ── TOC ── */
  .toc {
    width: clamp(260px, 55vw, 380px);
    margin: 0 auto;
  }

  .toc-grid {
    display: flex;
    flex-direction: column;
  }

  .toc-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 1.5rem;
    align-items: center;
    padding: 0.65rem 0;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid transparent;
    opacity: 0;
    animation: tocReveal 0.6s ease forwards;
    animation-delay: calc(0.8s + var(--i) * 0.06s);
    transition: border-color var(--transition-smooth);
  }

  .toc-row:hover {
    border-bottom-color: var(--surface-border);
  }

  .toc-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    transition: color var(--transition-smooth),
                letter-spacing var(--transition-smooth);
  }

  .toc-desc {
    font-size: 0.78rem;
    color: var(--surface-text-secondary);
    text-align: right;
    transition: color var(--transition-smooth);
  }

  .toc-row:hover .toc-title {
    color: var(--surface-accent);
    letter-spacing: 0.1em;
  }

  .toc-row:hover .toc-desc {
    color: var(--surface-text);
  }

  @media (max-width: 480px) {
    .toc-row { grid-template-columns: 1fr; gap: 0.15rem 0; }
    .toc-desc { text-align: left; }
  }
</style>
