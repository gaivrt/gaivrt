---
import { getCollection, render } from 'astro:content';
import type { GetStaticPathsOptions } from 'astro';
import Layer1Layout from '../../../layouts/Layer1Layout.astro';
import BackLink from '../../../components/surface/BackLink.astro';
import Pagination from '../../../components/surface/Pagination.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const items = (await getCollection('publications'))
    .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0));
  return paginate(items, { pageSize: 20 });
}

const { page } = Astro.props;

let InlineContent: any = null;
if (page.total === 1) {
  const result = await render(page.data[0]);
  InlineContent = result.Content;
}
---

<Layer1Layout title="Publications — GAIVRT">
  <div class="surface-container">
    <BackLink />
    <main>
      <h1>Publications</h1>
      {page.total === 0 ? (
        <p class="empty">暂无内容。</p>
      ) : page.total === 1 ? (
        <article class="prose">
          <InlineContent />
        </article>
      ) : (
        <ul class="item-list">
          {page.data.map((item, i) => (
            <li style={`--i: ${i}`}>
              <a href={`/surface/publications/${item.id}`}>
                <span class="item-title">{item.data.title}</span>
              </a>
              <div class="pub-meta">
                {item.data.authors && <span class="authors">{item.data.authors}</span>}
                {item.data.venue && <span class="venue">{item.data.venue}</span>}
                {item.data.date && <time datetime={item.data.date.toISOString()}>{item.data.date.getFullYear()}</time>}
              </div>
            </li>
          ))}
        </ul>
      )}
      <Pagination page={page} base="/surface/publications" />
    </main>
  </div>
</Layer1Layout>

<style>
  h1 { margin: 0 0 var(--space-lg); }
  .empty { color: var(--surface-text-secondary); font-style: italic; }
  .item-list { list-style: none; padding: 0; }
  .item-list li {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--surface-border);
    opacity: 0;
    animation: rowReveal 0.4s ease forwards;
    animation-delay: calc(0.1s + var(--i) * 0.05s);
  }
  .item-title { font-size: 1.05rem; font-weight: 500; }
  .item-list li a:hover .item-title { text-decoration: underline; }
  .pub-meta { margin-top: var(--space-xs); font-size: 0.85rem; color: var(--surface-text-secondary); display: flex; gap: var(--space-sm); flex-wrap: wrap; }
  .venue { font-style: italic; }

  @keyframes rowReveal {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 767px) {
    .pub-meta { flex-direction: column; gap: var(--space-xs); }
  }
</style>
