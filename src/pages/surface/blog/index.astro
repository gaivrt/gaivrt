---
import { getCollection } from 'astro:content';
import Layer1Layout from '../../../layouts/Layer1Layout.astro';
import BackLink from '../../../components/surface/BackLink.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const heroPost = posts[0];
const gridPosts = posts.slice(1);
---

<Layer1Layout title="Blog — GAIVRT">
  <div class="surface-container">
    <BackLink />
    <main>
      <h1>Blog</h1>
      <p class="blog-intro">Thoughts on technology, research, and building things.</p>

      {posts.length === 0 ? (
        <p class="empty">No posts yet. Check back soon.</p>
      ) : (
        <>
          {/* Hero: latest post */}
          <article class="hero-post">
            <a href={`/surface/blog/${heroPost.id}`} class="hero-post-link">
              <h2 class="hero-title">{heroPost.data.title}</h2>
              {heroPost.data.description && (
                <p class="hero-desc">{heroPost.data.description}</p>
              )}
              <div class="hero-footer">
                <time datetime={heroPost.data.date.toISOString()}>
                  {heroPost.data.date.toLocaleDateString('zh-CN')}
                </time>
                {heroPost.data.tags.length > 0 && (
                  <div class="post-tags">
                    {heroPost.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                  </div>
                )}
              </div>
            </a>
          </article>

          {/* Grid: remaining posts */}
          {gridPosts.length > 0 && (
            <>
              <div class="section-rule" aria-hidden="true"></div>
              <ul class="post-grid">
                {gridPosts.map((post, i) => (
                  <li class="post-card" style={`--i: ${i}`}>
                    <a href={`/surface/blog/${post.id}`} class="post-card-link">
                      <div class="post-card-body">
                        <h2 class="post-title">{post.data.title}</h2>
                        {post.data.description && (
                          <p class="post-desc">{post.data.description}</p>
                        )}
                        <div class="post-footer">
                          <time datetime={post.data.date.toISOString()}>
                            {post.data.date.toLocaleDateString('zh-CN')}
                          </time>
                          {post.data.tags.length > 0 && (
                            <div class="post-tags">
                              {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                            </div>
                          )}
                        </div>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </>
          )}
        </>
      )}
    </main>
  </div>
</Layer1Layout>

<style>
  h1 { margin: 0 0 var(--space-sm); }

  .blog-intro {
    color: var(--surface-text-secondary);
    margin-bottom: var(--space-xl);
  }

  .empty {
    color: var(--surface-text-secondary);
    font-style: italic;
  }

  /* ── Hero Article ── */
  .hero-post {
    padding: var(--space-xl) var(--space-lg);
    border: 1px solid rgba(180, 165, 140, 0.15);
    border-radius: 8px;
    background: rgba(240, 235, 225, 0.5);
    transition: box-shadow var(--transition-smooth);
  }

  .hero-post:hover {
    box-shadow: 0 4px 20px rgba(60, 50, 35, 0.06);
  }

  .hero-post-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.3;
    margin: 0;
    transition: color var(--transition-smooth);
  }

  .hero-post-link:hover .hero-title {
    color: var(--surface-accent);
  }

  .hero-desc {
    font-size: clamp(0.9rem, 1.8vw, 1rem);
    color: var(--surface-text-secondary);
    line-height: 1.8;
    margin-top: var(--space-md);
  }

  .hero-footer {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
    padding-top: var(--space-sm);
    border-top: 1px solid rgba(180, 165, 140, 0.15);
    font-size: 0.82rem;
    color: var(--surface-text-secondary);
  }

  /* ── Section Divider ── */
  .section-rule {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--surface-border), transparent);
    margin: var(--space-xl) 0;
  }

  /* ── Post Grid ── */
  .post-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  /* ── Post Card ── */
  .post-card {
    border: 1px solid rgba(180, 165, 140, 0.12);
    border-radius: 6px;
    background: rgba(240, 235, 225, 0.4);
    overflow: hidden;
    opacity: 0;
    animation: cardReveal 0.5s ease forwards;
    animation-delay: calc(0.1s + var(--i) * 0.06s);
    transition: transform var(--transition-smooth),
                box-shadow var(--transition-smooth);
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(60, 50, 35, 0.08);
  }

  @keyframes cardReveal {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .post-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .post-card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    height: 100%;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
    margin: 0;
    transition: color var(--transition-smooth);
  }

  .post-card-link:hover .post-title {
    color: var(--surface-accent);
  }

  .post-desc {
    font-size: 0.88rem;
    color: var(--surface-text-secondary);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: var(--space-sm);
    border-top: 1px solid rgba(180, 165, 140, 0.1);
    font-size: 0.8rem;
    color: var(--surface-text-secondary);
  }

  time {
    white-space: nowrap;
  }

  .post-tags {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.72rem;
    padding: 0.2em 0.6em;
    border-radius: 3px;
    background: rgba(139, 94, 60, 0.08);
    color: var(--surface-accent);
    letter-spacing: 0.02em;
  }

  /* ── Dark mode ── */
  :global([data-theme="dark"]) .hero-post {
    background: rgba(28, 24, 18, 0.6);
    border-color: rgba(200, 185, 160, 0.08);
  }

  :global([data-theme="dark"]) .post-card {
    background: rgba(28, 24, 18, 0.5);
    border-color: rgba(200, 185, 160, 0.06);
  }

  :global([data-theme="dark"]) .post-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  :global([data-theme="dark"]) .hero-footer,
  :global([data-theme="dark"]) .post-footer {
    border-top-color: rgba(200, 185, 160, 0.08);
  }

  :global([data-theme="dark"]) .tag {
    background: rgba(196, 132, 92, 0.12);
    color: var(--surface-accent);
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .post-grid {
      grid-template-columns: 1fr;
    }

    .hero-post {
      padding: var(--space-lg) var(--space-md);
    }

    .post-card-body {
      padding: var(--space-md);
    }

    .post-desc {
      -webkit-line-clamp: 2;
    }
  }
</style>
